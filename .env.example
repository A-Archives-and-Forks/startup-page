# ─────────────────────────────────────────────────────────────────────────────
# startup-page environment variables
#
# Local dev:   run `make env-pull` (vercel env pull .env.local) instead of
#              filling this in by hand — Vercel is the source of truth.
# Vercel:      set these in Project → Settings → Environment Variables,
#              scoped per environment (Development / Preview / Production).
# Self-host:   omit everything for local-only mode, or see docs/environments.md
#              to run your own sync backend.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (baked into the JS bundle at build time — never put secrets here) ──

# Clerk publishable key. Omit entirely to run in local-only mode (no auth UI).
# Development/Preview: pk_test_...   Production: pk_live_...
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: origin of a remote API. Leave unset on Vercel (same-origin /api).
# VITE_API_URL=

# ── Serverless API (Vercel Functions — server-side only, never exposed) ──

# Neon Postgres connection string.
# Production: main branch   Preview: preview branch   Development: dev branch
DATABASE_URL=

# Clerk secret key (must be from the same Clerk instance as the publishable key).
CLERK_SECRET_KEY=

# Stripe. Development/Preview: test-mode keys   Production: live-mode keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Absolute URL Stripe checkout redirects back to.
# Optional on Vercel (falls back to the deployment's own URL).
# APP_URL=https://your-domain.com

# Comma-separated emails that get cloud sync without paying (owner/friends).
COMP_USER_EMAILS=tpholmes7@gmail.com

# Self-hosters running their own backend: set to "false" to give every
# signed-in user sync access without Stripe.
# REQUIRE_SUBSCRIPTION=true
